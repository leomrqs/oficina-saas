// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN // Dono do SaaS (Você)
  MANAGER     // Dono/Gerente da Oficina
  MECHANIC    // Mecânico da Oficina
}

enum OrderStatus {
  PENDING   // Orçamento Pendente
  APPROVED  // Aprovado / Em Execução
  COMPLETED // Finalizado / Pago
  CANCELED  // Cancelado
}

enum TransactionType {
  IN
  OUT
  EDIT
} 

enum FinancialType {
  INCOME  // Receita (Entrada)
  EXPENSE // Despesa (Saída)
}

enum FinancialStatus {
  PENDING // Pendente (A Receber / A Pagar)
  PAID    // Pago / Recebido
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model Tenant {
  id           String   @id @default(cuid())
  name         String
  cnpj         String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]
  customers    Customer[]
  vehicles     Vehicle[]
  orders       Order[]
  products     Product[]
  transactions InventoryTransaction[]
  orderItems   OrderItem[]
  financials   FinancialTransaction[]
  fixedExpenses FixedExpense[]

  @@map("tenants")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // Hash gerado pelo bcryptjs
  role      Role     @default(MECHANIC)
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  document     String?  @unique // CPF ou CNPJ
  phone        String?
  email        String?  // Novo
  
  // Endereço (Novos)
  cep          String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?

  notes        String?  @db.Text // Observações internas

  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vehicles     Vehicle[]
  orders       Order[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("customers")
}

model Vehicle {
  id         String   @id @default(cuid())
  plate      String   @unique
  brand      String   // Marca (ex: Fiat)
  model      String   // Modelo (ex: Palio)
  year       Int?
  
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orders     Order[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("vehicles")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  sku          String?  // Código da peça
  imageUrl     String?  // URL da foto (Uploadthing)
  category     String   // Ex: Escapamentos, Freios, Filtros
  location     String?  // Ex: Prateleira A2
  
  costPrice    Float    @default(0.0)
  sellingPrice Float    @default(0.0)
  
  stock        Int      @default(0)
  minStock     Int      @default(5) // Alerta de estoque baixo
  
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  transactions InventoryTransaction[]
  orderItems   OrderItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("products")
}

model InventoryTransaction {
  id        String          @id @default(cuid())
  type      TransactionType // IN (Entrada) ou OUT (Saída/Ajuste)
  quantity  Int
  reason    String?         // Motivo: "Compra fornecedor", "Ajuste manual", "Perda"
  
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime        @default(now())

  @@map("inventory_transactions")
}

model Order {
  id         String      @id @default(cuid())
  number     Int         @default(autoincrement()) // Número sequencial da OS (Ex: #1001)
  status     OrderStatus @default(PENDING) // PENDING = Orçamento, APPROVED = Em serviço, COMPLETED = Pago
  
  laborTotal Float       @default(0.0) // Total de mão de obra
  partsTotal Float       @default(0.0) // Total de peças
  discount   Float       @default(0.0) // Desconto concedido
  total      Float       @default(0.0) // Valor final
  
  mileage    String?     // Quilometragem (KM) - Importante para garantia de escapamento
  problem    String?     @db.Text // Reclamação do cliente
  notes      String?     @db.Text // Obs internas / Diagnóstico do mecânico
  
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id])

  vehicleId  String
  vehicle    Vehicle     @relation(fields: [vehicleId], references: [id])

  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  items      OrderItem[]
  financials   FinancialTransaction[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(cuid())
  name       String   // Nome da peça ou serviço (Ex: "Solda MIG" ou "Abraçadeira 2.5")
  isLabor    Boolean  @default(false) // True = Serviço (Não baixa estoque), False = Peça
  
  quantity   Int      @default(1)
  unitPrice  Float
  total      Float
  
  productId  String?  // Se for uma peça do estoque, liga aqui
  product    Product? @relation(fields: [productId], references: [id])
  
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model FinancialTransaction {
  id          String   @id @default(cuid())
  title       String   // Ex: "Conta de Luz", "OS #1001", "Compra Fornecedor X"
  type        FinancialType
  category    String   // Ex: "Impostos", "Fornecedores", "Receitas Operacionais"
  amount      Float
  status      FinancialStatus @default(PENDING)
  
  dueDate     DateTime // Data de vencimento
  paymentDate DateTime? // Data em que foi efetivamente pago/recebido
  
  notes       String?  @db.Text

  orderId     String?  // Se for gerado por uma OS, fica atrelado aqui
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("financial_transactions")
}

model FixedExpense {
  id          String   @id @default(cuid())
  title       String   // Ex: "Conta de Luz", "Aluguel"
  category    String   // Ex: "Água / Luz / Internet"
  amount      Float
  dueDay      Int      // Dia de vencimento no mês (1 a 31)
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("fixed_expenses")
}