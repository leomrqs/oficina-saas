// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN // Dono do SaaS (Você)
  MANAGER     // Dono/Gerente da Oficina
  MECHANIC    // Mecânico da Oficina
}

enum OrderStatus {
  PENDING   // Orçamento Pendente
  APPROVED  // Aprovado / Em Execução
  COMPLETED // Finalizado / Pago
  CANCELED  // Cancelado
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  customers Customer[]
  vehicles  Vehicle[]
  orders    Order[]

  @@map("tenants")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // Hash gerado pelo bcryptjs
  role      Role     @default(MECHANIC)
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  document  String?  @unique // CPF ou CNPJ
  phone     String?
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vehicles  Vehicle[]
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model Vehicle {
  id         String   @id @default(cuid())
  plate      String   @unique
  brand      String   // Marca (ex: Fiat)
  model      String   // Modelo (ex: Palio)
  year       Int?
  
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orders     Order[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("vehicles")
}

model Order {
  id         String      @id @default(cuid())
  status     OrderStatus @default(PENDING)
  total      Float       @default(0.0)
  notes      String?     @db.Text
  
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id])

  vehicleId  String
  vehicle    Vehicle     @relation(fields: [vehicleId], references: [id])

  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("orders")
}