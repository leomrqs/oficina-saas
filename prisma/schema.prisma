// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  MANAGER
  MECHANIC
}

enum OrderStatus {
  PENDING         // Orçamento
  APPROVED        // Orçamento Aprovado
  WAITING_PARTS   // Aguardando Peças (NOVO)
  IN_PROGRESS     // No Elevador (NOVO)
  READY           // Pronto p/ Entrega (NOVO)
  COMPLETED       // Finalizado/Pago
  CANCELED        // Cancelado
}

enum TransactionType {
  IN
  OUT
  EDIT
}

enum FinancialType {
  INCOME
  EXPENSE
}

enum FinancialStatus {
  PENDING
  PAID
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  cnpj          String?  @unique
  phone         String?  
  address       String?  
  logoUrl       String?  
  monthlyGoal   Float    @default(50000.0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  customers     Customer[]
  vehicles      Vehicle[]
  orders        Order[]
  products      Product[]
  transactions  InventoryTransaction[]
  orderItems    OrderItem[]
  financials    FinancialTransaction[]
  fixedExpenses FixedExpense[]
  employees     Employee[] 
  orderHistory  OrderHistory[]

  @@map("tenants")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   
  role      Role     @default(MECHANIC)
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@map("users")
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  cpf       String?
  phone     String?
  role      String?  
  isActive  Boolean  @default(true)
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orderMechanics OrderMechanic[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@map("employees")
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  document     String?  @unique 
  phone        String?
  email        String?  
  cep          String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  notes        String?  @db.Text 

  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vehicles     Vehicle[]
  orders       Order[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@map("customers")
}

model Vehicle {
  id         String   @id @default(cuid())
  plate      String   @unique
  brand      String   
  model      String   
  version    String?
  year       Int?
  
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orders     Order[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@index([customerId]) // INDEX DE PERFORMANCE
  @@map("vehicles")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  sku          String?  
  imageUrl     String?  
  category     String   
  location     String?  
  costPrice    Float    @default(0.0)
  sellingPrice Float    @default(0.0)
  stock        Int      @default(0)
  minStock     Int      @default(5) 
  
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  transactions InventoryTransaction[]
  orderItems   OrderItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@map("products")
}

model InventoryTransaction {
  id        String          @id @default(cuid())
  type      TransactionType 
  quantity  Int
  reason    String?         
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@index([productId]) // INDEX DE PERFORMANCE
  @@map("inventory_transactions")
}

model Order {
  id            String      @id @default(cuid())
  number        Int         @default(autoincrement()) 
  status        OrderStatus @default(PENDING) 
  
  laborTotal    Float       @default(0.0) 
  partsTotal    Float       @default(0.0) 
  discount      Float       @default(0.0) 
  advancePayment Float      @default(0.0)
  total         Float       @default(0.0) 
  
  mileage       String?     
  fuelLevel     String?     @default("1/2")
  deliveryDate  DateTime?   
  
  problem       String?     @db.Text 
  notes         String?     @db.Text 
  customerNotes String?     @db.Text 
  warrantyText  String?     @db.Text 
  photoUrl      String?     
  
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  vehicleId     String
  vehicle       Vehicle     @relation(fields: [vehicleId], references: [id])
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  items         OrderItem[]
  financials    FinancialTransaction[]
  mechanics     OrderMechanic[]
  history       OrderHistory[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@index([tenantId, status]) // INDEX DE PERFORMANCE COMPOSTO
  @@index([tenantId, updatedAt]) // INDEX DE PERFORMANCE COMPOSTO
  @@map("orders")
}

model OrderHistory {
  id          String   @id @default(uuid())
  oldStatus   String?  
  newStatus   String   
  notes       String?  
  createdAt   DateTime @default(now())

  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([orderId]) // INDEX DE PERFORMANCE
  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@map("order_history")
}

model OrderMechanic {
  id         String   @id @default(cuid())
  task       String?  
  
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([orderId]) // INDEX DE PERFORMANCE
  @@index([employeeId]) // INDEX DE PERFORMANCE
  @@map("order_mechanics")
}

model OrderItem {
  id         String   @id @default(cuid())
  name       String   
  isLabor    Boolean  @default(false) 
  quantity   Int      @default(1)
  unitPrice  Float
  total      Float
  productId  String?  
  product    Product? @relation(fields: [productId], references: [id])
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([orderId]) // INDEX DE PERFORMANCE
  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@map("order_items")
}

model FinancialTransaction {
  id            String          @id @default(cuid())
  title         String   
  type          FinancialType 
  category      String   
  amount        Float
  status        FinancialStatus @default(PENDING) 
  paymentMethod String? 
  dueDate       DateTime 
  paymentDate   DateTime? 
  notes         String?         @db.Text
  orderId       String?  
  order         Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@index([tenantId, paymentDate]) // INDEX DE PERFORMANCE COMPOSTO
  @@index([tenantId, dueDate]) // INDEX DE PERFORMANCE COMPOSTO
  @@map("financial_transactions")
}

model FixedExpense {
  id        String   @id @default(cuid())
  title     String   
  category  String   
  amount    Float
  dueDay    Int      
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId]) // INDEX DE PERFORMANCE
  @@map("fixed_expenses")
}