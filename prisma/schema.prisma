// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  MANAGER
  MECHANIC
}

enum OrderStatus {
  PENDING
  APPROVED
  COMPLETED
  CANCELED
}

enum TransactionType {
  IN
  OUT
  EDIT
}

// VOLTAMOS COM OS ENUMS CORRETOS AQUI!
enum FinancialType {
  INCOME
  EXPENSE
}

enum FinancialStatus {
  PENDING
  PAID
}

model Tenant {
  id           String   @id @default(cuid())
  name         String
  cnpj         String?  @unique
  phone        String?  
  address      String?  
  logoUrl      String?  
  monthlyGoal  Float    @default(50000.0)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]
  customers    Customer[]
  vehicles     Vehicle[]
  orders       Order[]
  products     Product[]
  transactions InventoryTransaction[]
  orderItems   OrderItem[]
  financials   FinancialTransaction[]
  fixedExpenses FixedExpense[]
  employees    Employee[] 

  @@map("tenants")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   
  role      Role     @default(MECHANIC)
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ==========================================
// MÓDULO DE RECURSOS HUMANOS (EQUIPE)
// ==========================================
model Employee {
  id        String   @id @default(cuid())
  name      String
  cpf       String?
  phone     String?
  role      String?  
  isActive  Boolean  @default(true)
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orderMechanics OrderMechanic[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

// ==========================================
// MÓDULO DE CLIENTES E LOGÍSTICA
// ==========================================
model Customer {
  id           String   @id @default(cuid())
  name         String
  document     String?  @unique 
  phone        String?
  email        String?  
  cep          String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  notes        String?  @db.Text 

  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vehicles     Vehicle[]
  orders       Order[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("customers")
}

model Vehicle {
  id         String   @id @default(cuid())
  plate      String   @unique
  brand      String   
  model      String   
  year       Int?
  
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orders     Order[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("vehicles")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  sku          String?  
  imageUrl     String?  
  category     String   
  location     String?  
  costPrice    Float    @default(0.0)
  sellingPrice Float    @default(0.0)
  stock        Int      @default(0)
  minStock     Int      @default(5) 
  
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  transactions InventoryTransaction[]
  orderItems   OrderItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("products")
}

model InventoryTransaction {
  id        String          @id @default(cuid())
  type      TransactionType 
  quantity  Int
  reason    String?         
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@map("inventory_transactions")
}

// ==========================================
// MÓDULO DE OS (REWORK MÁXIMO)
// ==========================================
model Order {
  id            String      @id @default(cuid())
  number        Int         @default(autoincrement()) 
  status        OrderStatus @default(PENDING) 
  
  laborTotal    Float       @default(0.0) 
  partsTotal    Float       @default(0.0) 
  discount      Float       @default(0.0) 
  total         Float       @default(0.0) 
  
  // DADOS DA VISTORIA
  mileage       String?     
  fuelLevel     String?     @default("1/2")
  deliveryDate  DateTime?   
  
  // TEXTOS E OBSERVAÇÕES
  problem       String?     @db.Text 
  notes         String?     @db.Text 
  customerNotes String?     @db.Text 
  warrantyText  String?     @db.Text 
  photoUrl      String?     
  
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  vehicleId     String
  vehicle       Vehicle     @relation(fields: [vehicleId], references: [id])
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  items         OrderItem[]
  financials    FinancialTransaction[]
  mechanics     OrderMechanic[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("orders")
}

// Tabela de Ligação
model OrderMechanic {
  id         String   @id @default(cuid())
  task       String?  
  
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("order_mechanics")
}

model OrderItem {
  id         String   @id @default(cuid())
  name       String   
  isLabor    Boolean  @default(false) 
  quantity   Int      @default(1)
  unitPrice  Float
  total      Float
  productId  String?  
  product    Product? @relation(fields: [productId], references: [id])
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ==========================================
// MÓDULO FINANCEIRO
// ==========================================
model FinancialTransaction {
  id          String   @id @default(cuid())
  title       String   
  type        FinancialType // <-- VOLTOU O ENUM SEGURO
  category    String   
  amount      Float
  status      FinancialStatus @default(PENDING) // <-- VOLTOU O ENUM SEGURO
  paymentMethod String? 
  dueDate     DateTime 
  paymentDate DateTime? 
  notes       String?  @db.Text
  orderId     String?  
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("financial_transactions")
}

model FixedExpense {
  id          String   @id @default(cuid())
  title       String   
  category    String   
  amount      Float
  dueDay      Int      
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("fixed_expenses")
}